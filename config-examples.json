  "openai_compatible_example": {
    "target": {
      "baseUrl": "http://localhost:4000",
      "agentEndpoint": "/v1/chat/completions",
      "applicationDetails": "OpenAI-compatible API endpoint for testing prompt injection and content filtering vulnerabilities.",
      "customApiTemplate": {
        "method": "POST",
        "headers": { "Content-Type": "application/json" },
        "bodyTemplate": "{\"model\": \"gpt-4.1-mini\", \"messages\": [{\"role\": \"user\", \"content\": \"{{message}}\"}]}",
        "responsePath": "choices[0].message.content"
      }
    },
    "codebasePath": null,
    "codebaseRepo": "https://github.com/sundi133/demo-agentic-app.git",
    "codebaseRepoBranch": "main",
    "auth": {
      "toolCallsPath": "",
      "userInfoPath": "",
      "guardrailsPath": ""
    },
    "sensitivePatterns": ["api_key", "secret", "token", "password"],
    "attackConfig": {
      "adaptiveRounds": 2,
      "maxAttacksPerCategory": 3,
      "llmProvider": "anthropic",
      "llmModel": "claude-sonnet-4-20250514",
      "enableLlmGeneration": true,
      "maxMultiTurnSteps": 15,
      "enableMultiTurnGeneration": true,
      "multiTurnGenerationRate": 0.4,
      "enableAdaptiveMultiTurn": true,
      "maxAdaptiveTurns": 15,
      "requireReviewConfirmation": false,
      "enabledCategories": [
