{
  "target": {
    "type": "http_agent",
    "baseUrl": "http://localhost:4000",
    "agentEndpoint": "/v1/chat/completions",
    "applicationDetails": "LiteLLM proxy server running gpt-4.1-mini model. Provides OpenAI-compatible API for various LLM providers. Testing for prompt injection, content filtering bypass, and guardrail evasion.",
    "customApiTemplate": {
      "method": "POST",
      "headers": {
        "Content-Type": "application/json"
      },
      "bodyTemplate": "{\"model\": \"qwen3.5-27b\", \"messages\": [{\"role\": \"user\", \"content\": \"{{message}}\"}]}",
      "responsePath": "choices[0].message.content"
    }
  },
  "codebasePath": null,
  "codebaseGlob": "**/*.ts",
  "policyFile": "policies/strict.json",
  "auth": {
    "methods": ["none"],
    "jwtSecret": "not-needed",
    "credentials": [],
    "apiKeys": {}
  },
  "requestSchema": {
    "messageField": "message",
    "roleField": "role",
    "apiKeyField": "api_key",
    "guardrailModeField": "guardrail_mode"
  },
  "responseSchema": {
    "responsePath": "choices[0].message.content",
    "toolCallsPath": "choices[0].message.tool_calls",
    "userInfoPath": "user",
    "guardrailsPath": "guardrails"
