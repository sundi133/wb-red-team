{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": false,
    "skipLibCheck": true
  },
  "include": ["*.ts", "lib/**/*.ts", "attacks/**/*.ts", "attacks-mcp/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
